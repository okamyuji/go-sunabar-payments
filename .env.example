# アプリケーション設定
APP_ENV=local
APP_LOG_LEVEL=debug

# データベース ( ホスト/ポートは compose の MYSQL_HOST_PORT に合わせて変更 )
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app
DB_PASSWORD=app
DB_NAME=payments
# 開発時は make migrate-up で参照する DSN を直接指定することも可能
MIGRATE_DSN=mysql://app:app@tcp(127.0.0.1:3306)/payments?parseTime=true&loc=Asia%2FTokyo&multiStatements=true

# compose の host 側ポート ( 既存 3306 と衝突する場合は 3307 などに変更 )
MYSQL_HOST_PORT=3306

# sunabar
SUNABAR_BASE_URL=https://api.sunabar.gmo-aozora.com
SUNABAR_ACCESS_TOKEN=__set_your_token_from_sunabar_service_site__

# Outbox リレーワーカー
OUTBOX_POLL_INTERVAL=2s
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPT=10
OUTBOX_CONSUMER=gsp-relay
