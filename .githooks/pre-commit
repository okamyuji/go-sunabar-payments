#!/usr/bin/env bash
# CI と同じチェックを commit 前に直列実行する。
# make install-hooks で git config core.hooksPath を .githooks に向ける。
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

export GOTOOLCHAIN="${GOTOOLCHAIN:-go1.25.0}"

echo "[pre-commit] gitleaks staged scan"
if ! command -v gitleaks >/dev/null 2>&1; then
	echo "gitleaks is required. Install it with: brew install gitleaks"
	exit 1
fi
# .gitleaks.toml ( sunabar 固有ルール + allowlist ) を明示適用。
gitleaks git --staged --redact --no-banner --config "$ROOT_DIR/.gitleaks.toml"

echo "[pre-commit] CI tooling compatibility"
bash scripts/check-ci-tooling.sh

echo "[pre-commit] go fmt check"
GOFMT_OUT="$(gofmt -l .)"
if [ -n "$GOFMT_OUT" ]; then
	echo "gofmt diff:"
	echo "$GOFMT_OUT"
	exit 1
fi

echo "[pre-commit] go vet"
go vet ./...

echo "[pre-commit] staticcheck"
staticcheck ./...

echo "[pre-commit] golangci-lint"
golangci-lint run ./...

echo "[pre-commit] go build"
go build ./...

echo "[pre-commit] go test ( short race shuffle )"
go test -short -race -shuffle=on -count=1 ./...

echo "[pre-commit] go test ( integration )"
go test -race -shuffle=on -count=1 -tags=integration -timeout=10m ./...

echo "[pre-commit] OK"
